{
  "opt_in_env": "HARNESS_ALLOW_DANGEROUS_EVAL",
  "allow_network_env": "HARNESS_ALLOW_NETWORK_TASKS",
  "allowed_programs": [
    "awk",
    "bash",
    "cat",
    "cmp",
    "curl",
    "dd",
    "cut",
    "diff",
    "echo",
    "env",
    "find",
    "git",
    "grep",
    "head",
    "jq",
    "ls",
    "make",
    "nc",
    "node",
    "npm",
    "ping",
    "printf",
    "pwd",
    "py.test",
    "pytest",
    "python",
    "python3",
    "rg",
    "ruff",
    "sed",
    "sh",
    "sort",
    "tail",
    "test",
    "uniq",
    "wget",
    "wc",
    "xargs",
    "yarn",
    "zip",
    "zsh"
  ],
  "blocked_programs": [
    "docker",
    "kill",
    "killall",
    "mkfs",
    "osascript",
    "reboot",
    "rm",
    "rsync",
    "scp",
    "shutdown",
    "ssh",
    "sudo",
    "telnet",
    "truncate"
  ],
  "network_programs": [
    "curl",
    "nc",
    "ping",
    "scp",
    "ssh",
    "telnet",
    "wget"
  ],
  "guardrails": {
    "hooks": {
      "pre_tool_use": {
        "enabled": true,
        "allow": true,
        "allow_network_tools": true,
        "allow_dangerous_commands": true
      },
      "pre_run": {
        "enabled": true,
        "allow": true
      },
      "pre_retrieval": {
        "enabled": true,
        "allow": true
      },
      "pre_context_build": {
        "enabled": true,
        "allow": true
      },
      "pre_score_dispatch": {
        "enabled": true,
        "allow": true
      }
    }
  }
}
