{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bitterless-harness.dev/contracts/trajectory-record-v1.schema.json",
  "title": "Bitterless Harness Trajectory Record v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "trajectory_record_version",
    "run_id",
    "input_fingerprint",
    "overall_pass"
  ],
  "properties": {
    "trajectory_record_version": {
      "const": "v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "input_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "overall_pass": {
      "type": "boolean"
    },
    "failure_classifications": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "task": {
      "type": "object"
    },
    "context": {
      "type": "object"
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "transcript_excerpt": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "score": {
      "type": "object"
    },
    "patch_stats": {
      "type": "object"
    }
  }
}
