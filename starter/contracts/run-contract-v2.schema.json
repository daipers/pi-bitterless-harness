{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bitterless-harness.dev/contracts/run-contract-v2.schema.json",
  "title": "Bitterless Harness Run Contract v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_contract_version",
    "result_interface_version",
    "required_run_files",
    "required_directories",
    "required_task_sections",
    "result_schema_path",
    "result_template_path",
    "manifest_path",
    "event_log_path",
    "execution_profile",
    "policy_path",
    "context_dir",
    "context_manifest_path",
    "context_summary_path",
    "retrieval"
  ],
  "properties": {
    "run_contract_version": {
      "const": "v2"
    },
    "result_interface_version": {
      "const": "v1"
    },
    "required_run_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 4
    },
    "required_directories": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 4
    },
    "required_task_sections": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 6
    },
    "result_schema_path": {
      "const": "result.schema.json"
    },
    "result_template_path": {
      "const": "result.template.json"
    },
    "manifest_path": {
      "const": "outputs/run_manifest.json"
    },
    "event_log_path": {
      "const": "run-events.jsonl"
    },
    "execution_profile": {
      "type": "string",
      "enum": [
        "strict",
        "capability"
      ]
    },
    "policy_path": {
      "type": "string",
      "minLength": 1
    },
    "context_dir": {
      "const": "context"
    },
    "context_manifest_path": {
      "const": "context/retrieval-manifest.json"
    },
    "context_summary_path": {
      "const": "context/retrieval-summary.md"
    },
    "retrieval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "source",
        "max_source_runs",
        "max_artifacts_per_run",
        "max_artifact_bytes"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "source": {
          "const": "prior_runs"
        },
        "max_source_runs": {
          "type": "integer",
          "minimum": 1
        },
        "max_artifacts_per_run": {
          "type": "integer",
          "minimum": 1
        },
        "max_artifact_bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
